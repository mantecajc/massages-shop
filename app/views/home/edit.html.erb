<%= turbo_frame_tag "modal" do %>
  <%= tag.div data: { controller: "turbo-modal" }, class: "p-5 bg-slate-300 absolute z-10 top-10 right-10 rounded-md w-96 break-words", style: "padding: 30px;" do %>
    <h1 class="font-bold text-4xl">Edite home</h1>
    <%= render "form", home: @home %>
    <%= button_tag "Fermer", data: { action: "turbo-modal#hideModal" }, type: "button", class: "rounded-lg py-3 px-5 bg-red-600 text-white" %>
  <% end %>
<% end %>