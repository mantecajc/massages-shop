<!DOCTYPE html>
<html>
  <head>
    <title>LESMassagesDePauline</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <div class="nav_logo ml-11 md:ml-36">
        <img src="<%= asset_path 'logo.svg' %>" alt="logo">
      </div>
      <div id="items" class="nav_items bg-[#347E7F] text-[#FBFBF7] text-[26px] md:text-[#347E7F] md:bg-[#FBFBF7] md:text-[22px]" >
        <a href="#" class="py-10 md:mr-6">Les massages</a>
        <a href="#" class="md:mr-6">Infos pratiques</a>
      </div>
      <div id="toggle" class="nav_toggle">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </nav>
    <script>
      toggle.onclick = () =>{
        items.classList.toggle("open")
        toggle.classList.toggle("close")
      }
    </script>
    <%= yield %>
  </body>
</html>



