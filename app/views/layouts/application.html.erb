<!DOCTYPE html>
<html>
  <head>
    <title>LESMassagesDePauline</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <div class="bg-[#FBFBF7] font-confortaa flex justify-between text-[#347E7F] border-b border-[#347E7F] h-[135px]" id="navbar">
        <div class="ml-11 md:ml-36">
          <img src="<%= asset_path 'logo.svg' %>" alt="logo">
        </div>
        <!--<a class="brand" href="#">My portfolio</a>-->
        <div class="flex items-center mr-11 lg:hidden">
          <img src="<%= asset_path 'menu.svg' %>" alt="menu" class="w-[30px] h-[30px]" onclick="openMenu();">
        </div>
        <div id="menu" class="lg:flex hidden items-center text-[22px] mr-36">
          <a href="#" class="pr-8">Les massages</a>
          <!--
            <a href="#">Offrir un soin</a>
          -->
          <a href="#">Infos pratiques</a>
        </div>
      </div>
    </nav>

    <script>
      function openMenu() {
        let menu = document.getElementById('menu');

        if(menu.classList.contains('hidden')) {
          menu.classList.remove('hidden');
        } else {
          menu.classList.add('hidden');
        }
      }
    </script>

    <div class="w-full lg:w-auto block lg:flex lg:items-center lg:inline-block hidden" id="navbar">
      <a class="brand" href="#">Les massages de Pauline</a>
    </div>
    <%= yield %>
  </body>
</html>
